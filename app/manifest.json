{
  "manifest_version": 3,
  "name": "Marriage Map",
  "version": "0.1.1",
  "description": "Explore marriage, divorce, fertility, polygamy, marriage age and more for every country — on an interactive globe with a history-of-marriage timeline.",
  "homepage_url": "https://42-apps.github.io/marriage-map/",
  "icons": { "16": "icons/icon16.png", "32": "icons/icon32.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "action": {
    "default_title": "Open Marriage Map",
    "default_icon": { "16": "icons/icon16.png", "32": "icons/icon32.png", "48": "icons/icon48.png" }
  },
  "background": { "service_worker": "background.js" }
}
